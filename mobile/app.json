{
  "expo": {
    "name": "I'm Here",
    "slug": "imhere",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "imhere",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.imhere.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para mostrar bares, restaurantes e baladas próximos.",
        "NSCameraUsageDescription": "Tire fotos para sua galeria e No Momento.",
        "NSPhotoLibraryUsageDescription": "Selecione fotos para enviar no chat e sua galeria."
      }
    },
    "android": {
      "package": "app.imhere.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0b"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Usamos sua localização para mostrar lugares próximos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Selecione fotos para o I'm Here.",
          "cameraPermission": "Tire fotos diretamente do app."
        }
      ]
    ],
    "extra": {
      "router": { "origin": false }
    }
  }
}
