# ===================================================================
# I'm Here · Variáveis de ambiente
# Copie para .env.local e preencha. Sem .env.local, o app usa mocks.
# ===================================================================

# --- Supabase --------------------------------------------------------
# Projeto criado em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Efí Bank (https://dev.efipay.com.br) ---------------------------
# Aplicação OAuth da sua conta Efí
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# Sandbox ou produção
EFI_SANDBOX=true
# PIX
EFI_PIX_KEY=
# Webhook (precisa estar publicado em HTTPS)
EFI_WEBHOOK_URL=https://imhere.app/api/webhooks/efi
# Certificado .p12 do mTLS (path local)
EFI_CERT_PATH=./.efi-cert.p12

# --- Google Maps / Mapbox -------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- OneSignal (push notifications) ---------------------------------
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- App URL --------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3010
